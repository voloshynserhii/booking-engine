generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- СИСТЕМА КОРИСТУВАЧІВ ---

enum UserRole {
  OWNER
  MANAGER
  STAFF
  GUEST
}

enum MealPlan {
  NONE
  BREAKFAST
  HALF_BOARD
  FULL_BOARD
  ALL_INCLUSIVE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CheckInStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String?     // Для власної авторизації
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  hotelUsers    HotelUser[]
  hotelsOwned   Hotel[]     @relation("HotelOwner")
  reviews       Review[]
}

model HotelUser {
  id      String   @id @default(cuid())
  userId  String
  hotelId String
  role    UserRole @default(STAFF)

  user    User     @relation(fields: [userId], references: [id])
  hotel   Hotel    @relation(fields: [hotelId], references: [id])

  @@unique([userId, hotelId])
}

// --- ГОТЕЛЬ ТА НОМЕРИ ---

model Hotel {
  id           String   @id @default(cuid())
  ownerId      String
  name         String
  description  String?
  starRating   Int?
  timezone     String   @default("UTC")
  currency     String   @default("EUR")
  
  // Деталізація адреси
  address      String
  city         String
  countryCode  String   // ISO 3166-1 alpha-2 (напр. "UA")
  latitude     Float?
  longitude    Float?

  checkInTime  String   @default("14:00")
  checkOutTime String   @default("11:00")
  imageUrls    String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner      User        @relation("HotelOwner", fields: [ownerId], references: [id])
  hotelUsers HotelUser[]
  rooms      Room[]
  ratePlans  RatePlan[]  // Нове: тарифи
  bookings   Booking[]
  amenities  Amenity[]   @relation("HotelAmenities")
  reviews    Review[]
  promotions Promotion[]
  taxes      Tax[]
}

model Room {
  id           String   @id @default(cuid())
  hotelId      String
  name         String
  roomType     String   // STANDARD, DELUXE тощо
  maxGuests    Int
  quantity     Int      @default(1) // Кількість фізичних одиниць
  imageUrls    String[] // Масив URL зображень кімнати
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel        Hotel           @relation(fields: [hotelId], references: [id])
  inventories  RoomInventory[]
  prices       RoomPrice[]     // Ціни на кожен день
  bookings     Booking[]
  amenities    Amenity[]       @relation("RoomAmenities")
  ratePlans    RatePlan[]      // Many-to-many: which rate plans apply to this room
}

// --- ЦІНОУТВОРЕННЯ ТА НАЯВНІСТЬ ---

model RatePlan {
  id          String   @id @default(cuid())
  hotelId     String
  name        String   // напр. "Standard Rate", "Non-Refundable"
  description String?
  mealPlan    MealPlan @default(NONE)
  isRefundable Boolean @default(true)
  
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
  rooms       Room[]   // Many-to-many: which rooms this rate plan applies to
  bookings    Booking[]
}

model RoomPrice {
  id         String   @id @default(cuid())
  roomId     String
  date       DateTime @db.Date
  price      Decimal  @db.Decimal(10, 2) // Використовуємо Decimal для грошей!
  
  room       Room     @relation(fields: [roomId], references: [id])

  @@unique([roomId, date])
}

enum RoomInventoryStatus {
  available
  blocked
  sold_out
}

model RoomInventory {
  roomTypeId     String
  date           DateTime @db.Date
  totalInventory Int
  bookedCount    Int      @default(0)
  status         RoomInventoryStatus @default(available)
  
  room           Room     @relation(fields: [roomTypeId], references: [id])

  @@id([roomTypeId, date])
  @@index([date])
}

// --- БРОНЮВАННЯ ТА ПЛАТЕЖІ ---

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

model Booking {
  id            String        @id @default(cuid())
  hotelId       String
  roomId        String
  ratePlanId    String
  guestId       String
  status        BookingStatus @default(PENDING)
  
  checkInDate   DateTime      @db.Date
  checkOutDate  DateTime      @db.Date
  
  totalPrice    Decimal       @db.Decimal(10, 2)
  priceAtBooking Decimal      @db.Decimal(10, 2) // Snapshot of nightly price at booking time
  currency      String
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  room          Room          @relation(fields: [roomId], references: [id])
  ratePlan      RatePlan      @relation(fields: [ratePlanId], references: [id])
  guest         Guest         @relation(fields: [guestId], references: [id])
  
  payments      Payment[]
  messages      Message[]
  checkInSessions CheckInSession[]
  bookingGuests BookingGuest[]

  @@index([hotelId, checkInDate, checkOutDate])
  @@index([status])
}

model Guest {
  id        String   @id @default(cuid())
  email     String
  phone     String?
  firstName String
  lastName  String
  
  bookings  Booking[]
  bookingGuests BookingGuest[]
}

model BookingGuest {
  id        String @id @default(cuid())
  bookingId String
  guestId   String?
  firstName String
  lastName  String
  email     String?
  phone     String?
  
  booking   Booking @relation(fields: [bookingId], references: [id])
  guest     Guest?  @relation(fields: [guestId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique // ID з Stripe/PayPal
  
  createdAt     DateTime      @default(now())
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

// --- ІНШЕ ---

model Amenity {
  id      String   @id @default(cuid())
  name    String   @unique
  category String? // Bathroom, Bedroom, Media
  hotels  Hotel[]  @relation("HotelAmenities")
  rooms   Room[]   @relation("RoomAmenities")
}

model Promotion {
  id          String   @id @default(cuid())
  hotelId     String
  name        String
  description String?
  discountType String  // PERCENTAGE, FIXED
  discountValue Decimal @db.Decimal(10, 2)
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean  @default(true)
  
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
}

model Tax {
  id          String   @id @default(cuid())
  hotelId     String
  name        String   // VAT, City Tax
  rate        Decimal  @db.Decimal(5, 2) // 0.21 for 21%
  isPercentage Boolean @default(true)
  
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  hotelId   String
  userId    String
  bookingId String?
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  
  hotel     Hotel    @relation(fields: [hotelId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String   // User ID
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model CheckInSession {
  id        String        @id @default(cuid())
  bookingId String
  status    CheckInStatus @default(PENDING)
  createdAt DateTime      @default(now())
  
  booking   Booking       @relation(fields: [bookingId], references: [id])
}