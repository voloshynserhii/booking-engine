generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  hotelUsers HotelUser[]
  hotels     Hotel[] // Hotels owned by this user
  reviews    Review[]
}

model Hotel {
  id          String  @id @default(cuid())
  ownerId     String
  name        String
  description String?
  starRating  Int?
  timezone    String
  currency    String

  // Location
  address   String?
  city      String?
  state     String?
  country   String?
  zipCode   String?
  latitude  Float?
  longitude Float?

  // Contact
  email   String?
  phone   String?
  website String?

  // Policies
  checkInTime  String?
  checkOutTime String?

  // Media
  imageUrls String[]

  createdAt DateTime @default(now())

  owner      User        @relation(fields: [ownerId], references: [id])
  hotelUsers HotelUser[]
  rooms      Room[]
  bookings   Booking[]
  amenities  Amenity[]   @relation("HotelAmenities")
  reviews    Review[]
  promotions Promotion[]
  taxes      Tax[]
}

model HotelUser {
  id      String @id @default(cuid())
  userId  String
  hotelId String
  role    String // OWNER | MANAGER | STAFF

  user  User  @relation(fields: [userId], references: [id])
  hotel Hotel @relation(fields: [hotelId], references: [id])
}

model Room {
  id           String  @id @default(cuid())
  hotelId      String
  name         String
  description  String?
  roomType     String? // STANDARD | DELUXE | SUITE
  bedType      String? // KING | QUEEN | TWIN
  numberOfBeds Int?
  maxGuests    Int
  size         Float? // in square meters
  quantity     Int     @default(1) // Number of physical rooms of this type
  basePrice    Float

  // Media
  imageUrls String[]

  createdAt DateTime @default(now())

  hotel           Hotel            @relation(fields: [hotelId], references: [id])
  roomInventories RoomInventory[]
  bookings        Booking[]
  amenities       Amenity[]        @relation("RoomAmenities")
}

model Amenity {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String? // URL or icon name
  createdAt   DateTime @default(now())

  hotels Hotel[] @relation("HotelAmenities")
  rooms  Room[]  @relation("RoomAmenities")
}

enum RoomInventoryStatus {
  available
  blocked
  sold_out
}

model RoomInventory {
  roomTypeId     String
  date           DateTime @db.Date
  totalInventory Int
  bookedCount    Int
  status         RoomInventoryStatus

  room Room @relation(fields: [roomTypeId], references: [id])

  @@id([roomTypeId, date])
}

model Guest {
  id        String   @id @default(cuid())
  email     String
  phone     String?
  fullName  String
  createdAt DateTime @default(now())

  bookings Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  hotelId      String
  roomId       String
  guestId      String?
  status       String // PENDING | CONFIRMED | CANCELLED
  checkInDate  DateTime
  checkOutDate DateTime
  totalPrice   Float
  createdAt    DateTime @default(now())

  hotel           Hotel            @relation(fields: [hotelId], references: [id])
  room            Room             @relation(fields: [roomId], references: [id])
  guest           Guest?           @relation(fields: [guestId], references: [id])
  bookingGuests   BookingGuest[]
  payments        Payment[]
  checkInSessions CheckInSession[]
  messages        Message[]
  reviews         Review[]
}

model BookingGuest {
  id             String @id @default(cuid())
  bookingId      String
  fullName       String
  documentNumber String

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  bookingId String
  amount    Float
  status    String // PENDING | PAID | FAILED
  provider  String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model CheckInSession {
  id        String   @id @default(cuid())
  bookingId String
  token     String   @unique
  expiresAt DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  booking     Booking       @relation(fields: [bookingId], references: [id])
  checkInData CheckInData[]
}

model CheckInData {
  id               String  @id @default(cuid())
  checkInSessionId String
  guestName        String
  documentNumber   String
  documentPhotoUrl String?
  signed           Boolean @default(false)

  checkInSession CheckInSession @relation(fields: [checkInSessionId], references: [id])
}

model File {
  id        String   @id @default(cuid())
  url       String
  type      String // IMAGE | DOCUMENT
  size      Int
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  bookingId  String
  senderType String // GUEST | HOST
  content    String
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  hotelId   String
  userId    String?
  bookingId String?
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())

  hotel   Hotel    @relation(fields: [hotelId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
}

model Promotion {
  id            String   @id @default(cuid())
  hotelId       String
  code          String
  description   String?
  discountType  String // PERCENTAGE | FIXED
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id])
}

model Tax {
  id          String   @id @default(cuid())
  hotelId     String
  name        String // e.g., VAT, City Tax
  type        String // PERCENTAGE | FIXED
  value       Float
  isMandatory Boolean  @default(true)
  createdAt   DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id])
}
